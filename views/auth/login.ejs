<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Milk Tea Shop</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="auth-container">
    <div class="auth-card">
      <div class="logo">MilkTea</div>
      <div class="brand">Premium Bubble Tea</div>

      <% if (error) { %>
        <div class="alert alert-danger"><%= error %></div>
        <% if (typeof query !== 'undefined' && query) { %>
          <div style="background:rgba(0,0,0,0.4);border:1px solid rgba(255,107,107,0.3);border-radius:8px;padding:12px;margin-bottom:16px;text-align:left;">
            <div style="font-size:11px;color:var(--text-muted);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px;">SQL Query executed:</div>
            <code style="font-size:11px;color:var(--danger);word-break:break-all;display:block;line-height:1.6;"><%= query %></code>
            <div style="font-size:11px;color:var(--text-muted);margin-top:8px;">💡 Thử: <code style="color:var(--accent);">admin'--</code> để bypass mật khẩu</div>
          </div>
        <% } %>
      <% } %>

      <form action="/login" method="POST">
        <label>Username</label>
        <input type="text" name="username" placeholder="Enter your username" required>

        <label>Password</label>
        <input type="password" name="password" placeholder="Enter your password" required>

        <button type="submit">Sign In</button>
      </form>

      <p style="text-align:center;margin-top:16px;">
        <a href="/forgot-password" class="link" style="font-size:13px;color:var(--danger);">Quên mật khẩu?</a>
      </p>
      <p style="text-align:center;margin-top:8px;color:var(--text-muted);">
        Don't have an account? <a href="/register" class="link">Register</a>
      </p>
    </div>
  </div>
</body>
</html>