<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>A6: Data Exposure - Milk Tea Shop</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container">
    <nav>
      <div class="logo">MilkTea</div>
      <div class="nav-links">
        <a href="/user/dashboard">Home</a>
        <a href="/user/menu">Menu</a>
        <a href="/vuln/sqli">A1</a>
        <a href="/vuln/auth">A2</a>
        <a href="/vuln/xss">A3</a>
        <a href="/vuln/idor">A4</a>
        <a href="/vuln/config">A5</a>
        <a href="/vuln/data" class="active">A6</a>
      </div>
      <div class="nav-right">
        <a href="/logout" class="logout">Logout</a>
      </div>
    </nav>

    <div class="card">
      <span class="vuln-badge critical">⚠ A6: Sensitive Data Exposure</span>
      <h2>👥 Customer Database</h2>
      <p style="color:var(--text-muted);margin-bottom:20px;">
        Passwords are stored in <strong>plaintext</strong>. If an attacker dumps this table (e.g., via SQLi), they immediately have all credentials — no cracking required.
      </p>

      <div class="alert alert-danger" style="margin-bottom:20px;">
        ⚠ <strong>CRITICAL:</strong> Column <code>password</code> is stored and returned in plaintext!
      </div>

      <div class="table-wrapper">
        <table>
          <thead>
            <tr><th>ID</th><th>Username</th><th>Password</th><th>Email</th><th>Role</th><th>Balance</th></tr>
          </thead>
          <tbody>
            <% if (!users || users.length === 0) { %>
              <tr><td colspan="6" style="text-align:center;color:var(--text-muted);">No users found</td></tr>
            <% } else { %>
              <% users.forEach(function(u) { %>
                <tr>
                  <td><%= u.id %></td>
                  <td><strong><%= u.username %></strong></td>
                  <td style="font-family:monospace;color:var(--danger);font-weight:700;"><%= u.password %></td>
                  <td><%= u.email %></td>
                  <td><span class="badge badge-<%= u.role %>"><%= u.role %></span></td>
                  <td style="color:var(--success);">$<%= u.balance %></td>
                </tr>
              <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
      <div class="card" style="border-color:rgba(255,107,107,0.3);">
        <h3 style="color:var(--danger);margin-bottom:12px;">💡 Why This Is Critical</h3>
        <p style="color:var(--text-muted);">With plaintext passwords, an attacker who gains read access (via SQLi, DB backup leak, or insider threat) can immediately log in as any user — including admin — with no additional effort.</p>
        <p style="color:var(--text-muted);">This also enables <strong>credential stuffing</strong>: users often reuse passwords across sites.</p>
      </div>
      <div class="card" style="border-color:rgba(200,168,107,0.3);">
        <h3 style="color:var(--success);margin-bottom:12px;">✓ The Fix</h3>
        <pre style="font-family:monospace;font-size:12px;color:var(--text-muted);line-height:1.8;">// Store
const hash = await bcrypt.hash(password, 12);

// Verify
const ok = await bcrypt.compare(password, hash);

// Query — use parameterized
SELECT id FROM users
WHERE username = ?  ← placeholder</pre>
      </div>
    </div>
  </div>
</body>
</html>
