<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Reset Password - Milk Tea Shop</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="auth-container">
    <div class="auth-card" style="max-width:480px;">
      <div class="logo">MilkTea</div>
      <div class="brand">Set New Password</div>

      <span class="vuln-badge critical" style="display:inline-flex;margin-bottom:20px;">⚠ A2: Broken Authentication</span>

      <% if (success) { %>
        <div class="alert alert-success" style="text-align:left;margin-bottom:16px;">
          ✓ <%= success %>
        </div>
        <div style="background:rgba(0,0,0,0.3);border-radius:8px;padding:14px;text-align:left;margin-bottom:16px;">
          <div style="font-size:12px;color:var(--text-muted);margin-bottom:6px;">SQL thực thi:</div>
          <code style="font-size:12px;color:var(--danger);word-break:break-all;">
            UPDATE users SET password = '***' WHERE username = '<%= username %>'
          </code>
        </div>
        <a href="/login" class="btn" style="width:100%;justify-content:center;">→ Đăng nhập ngay</a>
      <% } else { %>

        <div style="background:rgba(255,107,107,0.05);border:1px solid rgba(255,107,107,0.2);border-radius:10px;padding:14px;text-align:left;margin-bottom:20px;">
          <div style="font-size:12px;color:var(--text-muted);margin-bottom:6px;">Đang reset mật khẩu cho:</div>
          <div style="font-size:16px;font-weight:700;color:var(--danger);">👤 <%= username %></div>
          <div style="font-size:11px;color:var(--text-muted);margin-top:6px;">
            Token: <code style="color:var(--accent);"><%= token %></code>
            → decode: <code style="color:var(--success);">base64 → "<%= username %>"</code>
          </div>
        </div>

        <% if (error) { %>
          <div class="alert alert-danger" style="text-align:left;"><%= error %></div>
        <% } %>

        <form action="/reset-password" method="POST" style="text-align:left;">
          <input type="hidden" name="token" value="<%= token %>">
          <label>Mật khẩu mới</label>
          <input type="password" name="newPassword" placeholder="Nhập mật khẩu mới" required autofocus>
          <button type="submit" style="width:100%;justify-content:center;">Đặt lại mật khẩu</button>
        </form>

        <div style="margin-top:16px;background:rgba(0,0,0,0.3);border-radius:8px;padding:14px;text-align:left;">
          <div style="font-size:11px;color:var(--text-muted);margin-bottom:6px;">Query sẽ chạy:</div>
          <code style="font-size:11px;color:var(--danger);word-break:break-all;">
            UPDATE users SET password = '<em style="color:var(--accent);">[newPassword]</em>' WHERE username = '<%= username %>'
          </code>
          <div style="font-size:11px;color:var(--text-muted);margin-top:8px;">
            ✗ Không kiểm tra token hết hạn &nbsp;|&nbsp;
            ✗ Không xác thực email &nbsp;|&nbsp;
            ✗ Query không parameterized
          </div>
        </div>
      <% } %>

      <p style="text-align:center;margin-top:20px;color:var(--text-muted);font-size:13px;">
        <a href="/login" class="link">← Quay lại đăng nhập</a>
      </p>
    </div>
  </div>
</body>
</html>
