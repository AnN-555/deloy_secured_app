<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Milk Tea Shop' %></title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container">
    <% if (typeof user !== 'undefined' && user) { %>
    <nav>
      <div class="logo">MilkTea</div>
      <div class="nav-links">
        <a href="/user/dashboard">Home</a>
        <a href="/user/menu">Menu</a>
        <a href="/user/cart">Cart</a>
        <a href="/user/orders">Orders</a>
        <a href="/vuln">Exploit Lab</a>
      </div>
      <div class="nav-search">
        <form action="/user/search" method="POST" style="display:flex;gap:6px;">
          <input type="text" name="q" placeholder="Search drinks..." autocomplete="off">
          <button type="submit" style="padding:6px 12px;">Search</button>
        </form>
      </div>
      <div class="nav-right">
        <span class="user-info"><%= user.username %></span>
        <a href="/logout" class="logout">Logout</a>
      </div>
    </nav>
    <% } %>