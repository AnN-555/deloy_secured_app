<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Order Detail - IDOR Demo</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container">
    <nav>
      <div class="logo">MilkTea</div>
      <div class="nav-links">
        <a href="/user/dashboard">Home</a>
        <a href="/user/menu">Menu</a>
        <a href="/vuln/sqli">A1</a>
        <a href="/vuln/auth">A2</a>
        <a href="/vuln/xss">A3</a>
        <a href="/vuln/idor" class="active">A4</a>
        <a href="/vuln/config">A5</a>
        <a href="/vuln/data">A6</a>
      </div>
      <div class="nav-right">
        <a href="/logout" class="logout">Logout</a>
      </div>
    </nav>

    <% if (error || !order) { %>
      <div class="card">
        <div class="alert alert-danger"><%= error || 'Order not found' %></div>
        <a href="/vuln/idor" class="btn secondary">← Back to IDOR Lab</a>
      </div>
    <% } else { %>

    <div class="alert alert-danger" style="margin-bottom:20px;">
      ⚠ <strong>IDOR Exploit Active</strong> — You are viewing order <strong>#<%= order.id %></strong> which belongs to user
      <strong>#<%= order.user_id %> (<%= order.owner_username %>)</strong>.
      No authorization check was performed.
    </div>

    <div class="card">
      <span class="vuln-badge critical">⚠ A4: IDOR — Unauthorized Access</span>
      <h2>📦 Order #<%= order.id %></h2>

      <div class="dashboard-grid" style="margin-top:20px;">
        <div class="stat-card">
          <div class="label">Owner (User ID)</div>
          <div class="value accent" style="font-size:20px;">#<%= order.user_id %> — <%= order.owner_username %></div>
        </div>
        <div class="stat-card">
          <div class="label">Total</div>
          <div class="value" style="color:var(--success);">$<%= order.total.toFixed(2) %></div>
        </div>
        <div class="stat-card">
          <div class="label">Status</div>
          <div class="value" style="font-size:16px;"><%= order.status %></div>
        </div>
      </div>

      <table style="margin-top:20px;">
        <tr><td style="color:var(--text-muted);width:160px;">Order Date</td><td><%= new Date(order.order_date).toLocaleString() %></td></tr>
        <% if (order.delivery_address) { %>
          <tr><td style="color:var(--text-muted);">Delivery Address</td><td><%= order.delivery_address %></td></tr>
        <% } %>
        <% if (order.notes) { %>
          <tr><td style="color:var(--text-muted);">Notes</td><td><%= order.notes %></td></tr>
        <% } %>
      </table>

      <% if (items && items.length > 0) { %>
        <h3 style="margin-top:24px;margin-bottom:12px;">Order Items</h3>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr><th>Item</th><th>Qty</th><th>Price</th><th>Subtotal</th></tr>
            </thead>
            <tbody>
              <% items.forEach(function(item) { %>
                <tr>
                  <td><%= item.image %> <%= item.name %></td>
                  <td><%= item.quantity %></td>
                  <td>$<%= item.price.toFixed(2) %></td>
                  <td style="color:var(--success);">$<%= (item.price * item.quantity).toFixed(2) %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>

    <div style="margin-top:16px;">
      <a href="/vuln/idor" class="btn secondary">← Back to IDOR Lab</a>
    </div>

    <% } %>
  </div>
</body>
</html>
