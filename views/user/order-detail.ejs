<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Order #<%= order.id %> - Milk Tea Shop</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container">
    <nav>
      <div class="logo">MilkTea</div>
      <div class="nav-links">
        <a href="/user/dashboard">Home</a>
        <a href="/user/menu">Menu</a>
        <a href="/user/cart">Cart</a>
        <a href="/user/orders">Orders</a>
        <a href="/user/profile">Profile</a>
      </div>
      <div class="nav-right">
        <a href="/logout" class="logout">Logout</a>
      </div>
    </nav>

    <div class="card">
      <div class="card-header">
        <h2 class="card-title">📦 Order #<%= order.id %></h2>
        <% var badgeBg = 'rgba(85,239,196,0.2)'; var badgeColor = 'var(--success)'; %>
        <% if (order.status === 'pending') { badgeBg = 'rgba(253,203,110,0.2)'; badgeColor = 'var(--warning)'; } %>
        <% if (order.status === 'cancelled') { badgeBg = 'rgba(255,107,107,0.2)'; badgeColor = 'var(--danger)'; } %>
        <span class="badge" style="background:<%= badgeBg %>;color:<%= badgeColor %>;"><%= order.status %></span>
      </div>

      <div class="dashboard-grid" style="margin-bottom:24px;">
        <div class="stat-card">
          <div class="label">Order Date</div>
          <div class="value" style="font-size:18px;"><%= new Date(order.order_date).toLocaleString() %></div>
        </div>
        <div class="stat-card">
          <div class="label">Total Amount</div>
          <div class="value" style="color:var(--success);">$<%= (order.total || 0).toFixed(2) %></div>
        </div>
      </div>

      <% if (order.delivery_address) { %>
        <div style="margin-bottom:20px;">
          <h3 style="margin-bottom:8px;">Delivery Address</h3>
          <p style="color:var(--text);"><%= order.delivery_address %></p>
        </div>
      <% } %>

      <% if (order.notes) { %>
        <div style="margin-bottom:20px;">
          <h3 style="margin-bottom:8px;">Notes</h3>
          <p style="color:var(--text);"><%= order.notes %></p>
        </div>
      <% } %>

      <h3 style="margin-bottom:12px;">Order Items</h3>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr><th>Item</th><th>Quantity</th><th>Price</th><th>Subtotal</th></tr>
          </thead>
          <tbody>
            <% if (items && items.length > 0) { %>
              <% items.forEach(function(item) { %>
                <tr>
                  <td>
                    <div style="display:flex;align-items:center;gap:12px;">
                      <span style="font-size:20px;"><%= item.image || '🧋' %></span>
                      <span><%= item.name %></span>
                    </div>
                  </td>
                  <td><%= item.quantity %></td>
                  <td>$<%= (item.price || 0).toFixed(2) %></td>
                  <td style="font-weight:600;">$<%= ((item.price || 0) * item.quantity).toFixed(2) %></td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr><td colspan="4" style="text-align:center;color:var(--text-muted);">No items in this order</td></tr>
            <% } %>
            <tr style="background:var(--bg-input);">
              <td colspan="3" style="text-align:right;font-weight:700;">Total:</td>
              <td style="font-weight:700;color:var(--success);">$<%= order.total.toFixed(2) %></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <a href="/user/orders" class="btn secondary" style="margin-top:16px;">← Back to Orders</a>
  </div>
</body>
</html>