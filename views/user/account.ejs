<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Account - Milk Tea Shop</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container">
    <nav>
      <div class="logo">MilkTea</div>
      <div class="nav-links">
        <a href="/user/dashboard">Home</a>
        <a href="/vuln/idor">Orders</a>
      </div>
      <div class="nav-right">
        <a href="/logout" class="logout">Logout</a>
      </div>
    </nav>

    <div class="card">
      <h2>📋 Order Details</h2>

      <div class="dashboard-grid" style="margin-top:20px;">
        <div class="stat-card">
          <div class="label">Order ID</div>
          <div class="value accent">#<%= account.id %></div>
        </div>
        <div class="stat-card">
          <div class="label">Account</div>
          <div class="value" style="font-size:20px;"><%= account.account_num %></div>
        </div>
      </div>

      <table style="margin-top:20px;">
        <tr><td style="color:var(--text-muted);width:150px;">Balance</td><td style="color:var(--success);font-size:20px;">$<%= account.balance %></td></tr>
      </table>
    </div>

    <a href="/vuln/idor" class="btn secondary" style="margin-top:16px;">← Back to Orders</a>
  </div>
</body>
</html>