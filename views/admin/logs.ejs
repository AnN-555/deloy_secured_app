<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Logs - Milk Tea Shop</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container">
    <nav>
      <div class="logo">MilkTea</div>
      <div class="nav-links">
        <a href="/user/dashboard">Home</a>
        <a href="/admin/users">Admin</a>
        <a href="/admin/logs">Logs</a>
      </div>
      <div class="nav-right">
        <a href="/logout" class="logout">Logout</a>
      </div>
    </nav>

    <div class="card">
      <h2>📋 System Logs</h2>
      <p style="color:var(--text-muted);margin-bottom:20px;">Recent shop activity</p>

      <div class="table-wrapper">
        <table>
          <thead>
            <tr><th>ID</th><th>Timestamp</th><th>Action</th><th>User ID</th><th>Data</th></tr>
          </thead>
          <tbody>
            <% if (logs.length === 0) { %>
              <tr><td colspan="5" style="text-align:center;color:var(--text-muted);">No logs available</td></tr>
            <% } else { %>
              <% logs.forEach(log => { %>
                <tr>
                  <td><%= log.id %></td>
                  <td><%= log.timestamp %></td>
                  <td><%= log.action %></td>
                  <td><%= log.user_id %></td>
                  <td><code><%= JSON.stringify(log.data) %></code></td>
                </tr>
              <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</body>
</html>